<Window x:Class="PrApprover.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PR Approver" Height="420" Width="560"
        Icon="appicon.ico"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Avatar + identity -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <Border Width="56" Height="56" CornerRadius="28" ClipToBounds="True"
                    Background="#EEE" BorderBrush="#CCC" BorderThickness="1">
                <Border.Clip>
                    <EllipseGeometry Center="28,28" RadiusX="28" RadiusY="28"/>
                </Border.Clip>
                <Image x:Name="AvatarImage" Stretch="UniformToFill"/>
            </Border>
            <StackPanel VerticalAlignment="Center" Margin="12,0,0,0">
                <TextBlock Text="Signed in as:" Foreground="#666" FontSize="11"/>
                <TextBlock x:Name="UserNameText" Text="(not signed in)" FontSize="16" FontWeight="SemiBold"/>
            </StackPanel>
        </StackPanel>

        <!-- Repo URL -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Repo URL:" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" x:Name="RepoUrlBox" Padding="6,4"
                     ToolTip="https://github.com/owner/repo  or  owner/repo"/>
        </Grid>

        <!-- API key + Get Token -->
        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="API Key:" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" x:Name="ApiKeyBox" Padding="6,4"
                     FontFamily="Consolas"
                     ToolTip="Fine-grained PAT with Pull requests: Read and write"/>
            <Button Grid.Column="2" x:Name="GetTokenButton" Content="Get Token"
                    Margin="8,0,0,0" Padding="10,4" Click="GetTokenButton_Click"/>
        </Grid>

        <!-- PR input -->
        <Grid Grid.Row="3" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="PR (URL or #):" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" x:Name="PrInputBox" Padding="6,4"
                     ToolTip="Full PR URL or just the PR number"/>
        </Grid>

        <!-- Approve button -->
        <Button Grid.Row="4" x:Name="ApproveButton" Content="Approve"
                Width="160" Height="44" FontSize="16" FontWeight="SemiBold"
                Background="#2DA44E" Foreground="White" BorderThickness="0"
                Cursor="Hand" Click="ApproveButton_Click"/>

        <!-- Status -->
        <TextBlock Grid.Row="5" x:Name="StatusText" Margin="0,12,0,0"
                   TextWrapping="Wrap" Foreground="#666"/>

        <!-- Compact PR info line -->
        <TextBlock Grid.Row="6" x:Name="PrInfoText" Margin="0,6,0,0"
                   FontSize="11" Foreground="#555" TextTrimming="CharacterEllipsis"/>
    </Grid>
</Window>
